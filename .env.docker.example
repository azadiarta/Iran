# ===========================================================================
# تنظیمات دیپلوی با Docker — این فایل را کپی کنید و نام آن را به ".env" تغییر دهید:
#
#   cp .env.docker.example .env
#
# سپس فقط همین ۵ مقدار زیر را پر کنید. بقیه تنظیمات (نام دیتابیس، پورت‌ها، و...)
# به‌صورت ثابت داخل docker-compose.yml تعریف شده‌اند و نیازی به تغییر ندارند.
# ===========================================================================

# ---------------------------------------------------------------------------
# ۱) PUBLIC_HOST — آدرسی که سایت روی آن در دسترس خواهد بود (بدون http/https)
#
#    سه حالت ممکن است:
#
#    الف) دارید یک دامنه واقعی دارید (مثلاً از طریق ثبت دامنه خریده‌اید) و یک
#         رکورد DNS از نوع A را به آی‌پی سرورتان اشاره داده‌اید:
#         PUBLIC_HOST=example.com
#         → در این حالت Caddy به‌طور خودکار گواهی HTTPS رایگان از Let's Encrypt
#           می‌گیرد و سایت روی https در دسترس خواهد بود. (رکورد DNS باید از قبل
#           درست تنظیم شده و منتشر شده باشد، وگرنه صدور گواهی شکست می‌خورد)
#
#    ب) فقط یک آی‌پی سرور دارید و دامنه‌ای نخریده‌اید:
#         PUBLIC_HOST=123.45.67.89
#         → Caddy به‌صورت خودکار روی HTTP ساده (بدون قفل سبز/HTTPS) اجرا می‌شود؛
#           هیچ خطایی رخ نمی‌دهد، فقط HTTPS خودکار برای آی‌پی ممکن نیست.
#
#    ج) فقط می‌خواهید روی همین سرور/کامپیوتر به‌صورت محلی تست کنید:
#         PUBLIC_HOST=localhost
# ---------------------------------------------------------------------------
PUBLIC_HOST=localhost

# ---------------------------------------------------------------------------
# ۲) PUBLIC_URL — همان آدرس بالا، اما این‌بار همراه با http:// یا https://
#
#    قانون ساده: اگر PUBLIC_HOST یک دامنه واقعی است (حالت الف)، از https:// استفاده
#    کنید. اگر آی‌پی یا localhost است (حالت‌های ب و ج)، از http:// استفاده کنید.
#
#    مثال‌ها (متناظر با مثال‌های بالا):
#      PUBLIC_URL=https://example.com
#      PUBLIC_URL=http://123.45.67.89
#      PUBLIC_URL=http://localhost
#
#    نکته: این مقدار باید همیشه دقیقاً «هم‌خانواده» با PUBLIC_HOST باشد (همان
#    آدرس، فقط با پیشوند http(s)://) — این تنها راهی است که فرانت‌اند، بک‌اند،
#    CORS و CSRF بدون نیاز به هیچ تنظیم دیگری به‌طور خودکار با هم هماهنگ شوند.
# ---------------------------------------------------------------------------
PUBLIC_URL=http://localhost

# ---------------------------------------------------------------------------
# ۳) SECRET_KEY — یک کلید مخفی و طولانی برای امنیت Django (هرگز آن را با کسی
#    به اشتراک نگذارید و آن را در گیت‌هاب/جای عمومی قرار ندهید)
#
#    برای ساخت یک مقدار تصادفی و امن، یکی از این دو روش را روی سرور اجرا کنید:
#
#      python3 -c "import secrets; print(secrets.token_urlsafe(64))"
#
#    یا اگر پایتون نصب نیست:
#
#      openssl rand -base64 64 | tr -d '\n'
#
#    خروجی را کپی کرده و جای‌گزین مقدار زیر کنید (بدون فاصله یا گیومه اضافه).
# ---------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-long-random-string

# ---------------------------------------------------------------------------
# ۴) POSTGRES_PASSWORD — رمز عبور دیتابیس PostgreSQL
#
#    یک رمز قوی و دلخواه انتخاب کنید (فقط حروف انگلیسی و عدد توصیه می‌شود تا با
#    کاراکترهای خاص مشکلی پیش نیاید). همین رمز به‌طور خودکار هم برای ساخت
#    دیتابیس و هم برای اتصال بک‌اند به آن استفاده می‌شود — جای دیگری لازم نیست
#    وارد شود.
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change-this-to-a-strong-password

# ---------------------------------------------------------------------------
# ۵) SITE_NAME — نام نمایشی سایت (اختیاری، فقط جنبه ظاهری دارد)
# ---------------------------------------------------------------------------
SITE_NAME=Group Fund
