SECRET_KEY=
DEBUG=True
DB_NAME=groupfund
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Production ────────────────────────────────────────────────────────────────
# This file is for running the backend directly (e.g. local development with
# `python manage.py runserver`). For a full one-command production deployment,
# see `.env.docker.example` at the repo root and DEPLOYMENT.md instead — the
# Docker Compose setup derives ALLOWED_HOSTS/CORS_ALLOWED_ORIGINS/
# CSRF_TRUSTED_ORIGINS/SECURE_SSL_REDIRECT automatically from a single
# PUBLIC_HOST/PUBLIC_URL pair, so you don't need to set any of these by hand.
#
# If you are running the backend outside Docker, set DEBUG=False, list your
# real domain(s) for ALLOWED_HOSTS, and your deployed frontend origin(s) for
# CORS_ALLOWED_ORIGINS, e.g.:
#   DEBUG=False
#   ALLOWED_HOSTS=yourdomain.com
#   CORS_ALLOWED_ORIGINS=https://yourdomain.com
#   SECURE_SSL_REDIRECT=True
#
# ─── Media storage (S3-compatible bucket, optional) ───────────────────────────
# The Docker Compose setup stores uploaded media (post images, payment
# receipts) in a persistent named volume — it survives rebuilds/restarts, so an
# S3-compatible bucket is NOT required. Only set AWS_STORAGE_BUCKET_NAME if you
# specifically want to serve media from a CDN/bucket (e.g. for global
# performance). Leave unset to keep using local disk storage (MEDIA_ROOT).
#   AWS_STORAGE_BUCKET_NAME=your-bucket-name
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_S3_REGION_NAME=auto
#   AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com   # non-AWS providers only
#   AWS_S3_CUSTOM_DOMAIN=                                                # optional CDN/public domain
#
# ─── CAPTCHA (Cloudflare Turnstile, optional) ──────────────────────────────────
# Verifies the CAPTCHA widget shown on public forms (login, register, contact,
# comments, contributions). Left unset, it defaults to Cloudflare's published
# "always passes" test key, so everything works in dev without an account —
# set a real secret key (from https://dash.cloudflare.com/?to=/:account/turnstile)
# before deploying publicly. Pair with NEXT_PUBLIC_TURNSTILE_SITE_KEY in the
# frontend's .env (see frontend/.env.example).
#   TURNSTILE_SECRET_KEY=
#
# ─── Password vault (superuser-only password recovery, optional) ─────────────
# Key for the pwvault app's at-rest/in-transit encryption layers. Left unset,
# it falls back to SECRET_KEY, so no action is needed for local development.
#   PWVAULT_SECRET_KEY=
