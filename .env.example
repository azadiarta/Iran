SECRET_KEY=
DEBUG=True
DB_NAME=groupfund
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Production (e.g. Railway) ────────────────────────────────────────────────
# Set DEBUG=False, list your real domain(s) for ALLOWED_HOSTS, and your deployed
# frontend origin(s) for CORS_ALLOWED_ORIGINS, e.g.:
#   DEBUG=False
#   ALLOWED_HOSTS=yourapp.up.railway.app,yourdomain.com
#   CORS_ALLOWED_ORIGINS=https://yourdomain.com
#   SECURE_SSL_REDIRECT=True
#
# NOTE — uploaded media files (post images, payment receipts) are stored on the
# local filesystem (MEDIA_ROOT) which is EPHEMERAL on platforms like Railway:
# uploads will be lost on every redeploy/restart. For persistent uploads in
# production, configure a cloud storage backend (e.g. django-storages + an
# S3-compatible bucket) before going live with real users.
