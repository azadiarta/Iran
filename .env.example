SECRET_KEY=
DEBUG=True
DB_NAME=groupfund
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Production (e.g. Railway) ────────────────────────────────────────────────
# Set DEBUG=False, list your real domain(s) for ALLOWED_HOSTS, and your deployed
# frontend origin(s) for CORS_ALLOWED_ORIGINS, e.g.:
#   DEBUG=False
#   ALLOWED_HOSTS=yourapp.up.railway.app,yourdomain.com
#   CORS_ALLOWED_ORIGINS=https://yourdomain.com
#   SECURE_SSL_REDIRECT=True
#
# ─── Media storage (S3-compatible bucket) ─────────────────────────────────────
# Railway's filesystem is ephemeral — uploaded media (post images, payment
# receipts) does NOT survive redeploys/restarts unless stored in a bucket.
# Set AWS_STORAGE_BUCKET_NAME to switch media storage from local disk to an
# S3-compatible bucket (AWS S3, Cloudflare R2, Backblaze B2, ...). Leave unset
# for local development (uploads are written to MEDIA_ROOT on local disk).
#   AWS_STORAGE_BUCKET_NAME=your-bucket-name
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_S3_REGION_NAME=auto
#   AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com   # non-AWS providers only
#   AWS_S3_CUSTOM_DOMAIN=                                                # optional CDN/public domain
