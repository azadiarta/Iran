NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_NAME=Group Fund

# Only needed in production if the backend stores media in an S3-compatible
# bucket/CDN (AWS_STORAGE_BUCKET_NAME set on the backend — see backend
# .env.example). Set this to that bucket/CDN's public origin so next/image
# is allowed to load images from it, e.g.:
#   NEXT_PUBLIC_MEDIA_URL=https://your-bucket.s3.amazonaws.com
#   NEXT_PUBLIC_MEDIA_URL=https://media.yourdomain.com
# Leave unset when the backend serves media locally (MEDIA_URL=/media/).
NEXT_PUBLIC_MEDIA_URL=
